# ─────────────────────────────────────────────────────────
# hydro-ai-tutor: API keys via environment variables
# ─────────────────────────────────────────────────────────
# 复制本文件到 ~/.hydro/.env 然后填入你需要的 API Key。
# 服务器重启后 (pm2 restart hydrooj) 才会读到新值。
#
# 这个插件按 provider 优先读取对应的专用 Key；如果没找到，
# 再用通用的 AI_TUTOR_API_KEY 作为兜底。
#
# 只需要填写你实际要用的那一行，其他可留空或删掉。

# ── DeepSeek（推荐，默认） ──
# 在 https://platform.deepseek.com/ 申请
DEEPSEEK_API_KEY=sk-c02fd80d750e498e800436eda422bbfc

# ── OpenAI ──
# 在 https://platform.openai.com/api-keys 申请
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 阿里 通义千问 (Dashscope) ──
# 在 https://dashscope.console.aliyun.com/ 申请
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Moonshot Kimi ──
# 在 https://platform.moonshot.cn/console/api-keys 申请
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 智谱 GLM ──
# 在 https://open.bigmodel.cn/usercenter/apikeys 申请
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxx

# ── 字节豆包 (火山方舟) ──
# 在 https://console.volcengine.com/ark 申请
# ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 通用 fallback（任何 provider 都用这个，除非上面专用 key 已填） ──
# AI_TUTOR_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
